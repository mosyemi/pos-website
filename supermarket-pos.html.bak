                <div class="col-6 col-md-4 col-lg-2">
                    <h5 class="h6 mb-3">Solutions</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="restaurant-pos.html" class="text-muted text-decoration-none">Restaurant POS</a></li>
                        <li class="mb-2"><a href="supermarket-pos.html" class="text-muted text-decoration-none">Supermarket POS</a></li>
                        <li class="mb-2"><a href="wine-spirits-pos.html" class="text-muted text-decoration-none">Wine & Spirits</a></li>
