<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact - POS Solutions</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="styles.css">
</head>
<body class="bg-gray-100 font-sans">
    <!-- Navigation Bar -->
    <nav class="bg-blue-600 text-white p-4 sticky top-0 z-10">
        <div class="container mx-auto flex justify-between items-center">
            <a href="index.html" class="text-2xl font-bold">POS Solutions</a>
            <div class="space-x-4">
                <a href="index.html" class="hover:underline">Home</a>
                <a href="about.html" class="hover:underline">About</a>
                <a href="services.html" class="hover:underline">Services</a>
                <a href="pos-software.html" class="hover:underline">POS Software</a>
                <a href="contact.html" class="hover:underline">Contact</a>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <section class="py-16">
        <div class="container mx-auto">
            <h1 class="text-4xl font-bold text-center mb-6">Contact Us</h1>
            <p class="text-lg text-gray-700 text-center mb-8">Reach out with any questions or inquiries.</p>
            <div class="max-w-lg mx-auto bg-white p-6 rounded-lg shadow-md">
                <div id="contact-form">
                    <div class="mb-4">
                        <label for="name" class="block text-gray-700">Name</label>
                        <input type="text" id="name" class="w-full p-2 border rounded" required>
                    </div>
                    <div class="mb-4">
                        <label for="email" class="block text-gray-700">Email</label>
                        <input type="email" id="email" class="w-full p-2 border rounded" required>
                    </div>
                    <div class="mb-4">
                        <label for="message" class="block text-gray-700">Message</label>
                        <textarea id="message" class="w-full p-2 border rounded" rows="5" required></textarea>
                    </div>
                    <button id="submit-btn" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Send Message</button>
                </div>
                <div id="success-message" class="hidden text-green-600 text-center">
                    <p>Message sent! We'll respond soon.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-800 text-white py-8">
        <div class="container mx-auto text-center">
            <p>© 2025 POS Solutions. All rights reserved.</p>
        </div>
    </footer>

    <script src="script.js"></script>
    
</body>
</html>
